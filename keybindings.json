[
  // SCROLLING
  {
    "key": "space f",
    "command": "vscode-neovim.send",
    "args": "<space>fzz",
    "when": "editorTextFocus && neovim.ctrlKeysNormal.f && neovim.init && neovim.mode != 'insert' && editorLangId not in 'neovim.editorLangIdExclusions'"
  },
  {
    "key": "space b",
    "command": "vscode-neovim.send",
    "args": "<space>bzz",
    "when": "editorTextFocus && neovim.ctrlKeysNormal.b && neovim.init && neovim.mode != 'insert' && editorLangId not in 'neovim.editorLangIdExclusions'"
  },
  {
    "key": "space d",
    "command": "vscode-neovim.send",
    "args": "<space>dzz", // FIXME: zz doesn't fully work
    "when": "editorTextFocus && neovim.ctrlKeysNormal.d && neovim.init && neovim.mode != 'insert' && editorLangId not in 'neovim.editorLangIdExclusions'"
  },
  {
    "key": "space u",
    "command": "vscode-neovim.send",
    "args": "<space>uzz", // FIXME: zz doesn't fully work
    "when": "editorTextFocus && neovim.ctrlKeysNormal.u && neovim.init && neovim.mode != 'insert' && editorLangId not in 'neovim.editorLangIdExclusions'"
  },
  {
    "key": "n",
    "command": "vscode-neovim.send",
    "args": "nzzzv", // FIXME: zz doesn't fully work
    "when": "editorTextFocus && neovim.init && neovim.mode != 'insert'"
  },
  {
    "key": "shift+n",
    "command": "vscode-neovim.send",
    "args": "Nzzzv", // FIXME: zz doesn't fully work
    "when": "editorTextFocus && neovim.init && neovim.mode != 'insert'"
  },

  // VISUAL MODE
  {
    "key": "ctrl+shift+v",
    "command": "vscode-neovim.send",
    "when": "editorTextFocus && neovim.ctrlKeysNormal.v && neovim.init && neovim.mode != 'insert' && editorLangId not in 'neovim.editorLangIdExclusions'"
  },
  {
    "key": "ctrl+shift+v",
    "command": "vscode-neovim.send",
    "when": "editorTextFocus && neovim.ctrlKeysInsert.v && neovim.init && neovim.mode == 'insert' && editorLangId not in 'neovim.editorLangIdExclusions'"
  },

  // LINES MOVEMENT
  {
    "key": "space j",
    "command": "editor.action.moveLinesDownAction",
    "when": "editorTextFocus && neovim.mode != 'insert'"
  },
  {
    "key": "space k",
    "command": "editor.action.moveLinesUpAction",
    "when": "editorTextFocus && neovim.mode != 'insert'"
  },

  // WORKBENCH NAVIGATION
  {
    "key": "ctrl+h",
    "command": "workbench.action.navigateLeft"
  },
  {
    "key": "ctrl+j",
    "command": "workbench.action.navigateDown"
  },
  {
    "key": "ctrl+k",
    "command": "workbench.action.navigateUp"
  },
  {
    "key": "ctrl+l",
    "command": "workbench.action.navigateRight"
  },

  // CHAT
  {
    "key": "space a",
    "command": "workbench.panel.chat.view.copilot.focus", // FIXME: doesn't work
    "when": "editorTextFocus && neovim.mode != 'insert'"
  },
  {
    "key": "space c",
    "command": "inlineChat.start", // FIXME: doesn't work
    "when": "editorTextFocus && neovim.mode != 'insert'"
  },

  // SIDEBAR
  {
    "key": "space e",
    "command": "workbench.action.toggleSidebarVisibility",
    "when": "editorTextFocus && neovim.mode != 'insert'"
  },

  // COMMAND MODE
  {
    "key": "space ;",
    "command": "vscode-neovim.send",
    "args": ":",
    "when": "editorTextFocus && neovim.mode != 'insert'"
  },

  // COMMENTS
  {
    "key": "g c",
    "command": "editor.action.commentLine",
    "when": "editorTextFocus && neovim.mode != 'insert'"
  },

  // BACKSPACE
  {
    "key": "ctrl+h",
    "command": "deleteLeft",
    "when": "textInputFocus"
  },

  // DISABLED KEYBINDINGS
  {
    "key": "escape",
    "command": "-vscode-neovim.escape",
    "when": "editorTextFocus && neovim.init && !dirtyDiffVisible && !findWidgetVisible && !inReferenceSearchEditor && !markersNavigationVisible && !notebookCellFocused && !notificationCenterVisible && !parameterHintsVisible && !referenceSearchVisible && neovim.mode == 'normal' && editorLangId not in 'neovim.editorLangIdExclusions'"
  },
  {
    "key": "escape",
    "command": "-vscode-neovim.escape",
    "when": "editorTextFocus && neovim.init && neovim.mode != 'normal' && editorLangId not in 'neovim.editorLangIdExclusions'"
  },
  {
    "key": "ctrl+a",
    "command": "-vscode-neovim.send",
    "when": "editorTextFocus && neovim.ctrlKeysInsert.a && neovim.init && neovim.mode == 'insert' && editorLangId not in 'neovim.editorLangIdExclusions'"
  },
  {
    "key": "ctrl+a",
    "command": "-vscode-neovim.send",
    "when": "editorTextFocus && neovim.ctrlKeysNormal.a && neovim.init && neovim.mode != 'insert' && editorLangId not in 'neovim.editorLangIdExclusions'"
  },
