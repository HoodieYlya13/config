  {
    "key": "backspace",
    "command": "-vscode-neovim.send",
    "when": "editorTextFocus && neovim.init && focusedView == 'workbench.panel.output' && neovim.mode != 'insert'"
  },
  {
    "key": "delete",
    "command": "-vscode-neovim.send",
